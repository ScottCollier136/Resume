KAFKA_RETENTION_CHECK_INTERVAL_MS=30000
KAFKA_RETENTION_HOURS=1
KAFKA_CLEANER_DELETE_RETENTION_MS=60000
KAFKA_SEGMENT_BYTES=104857600
